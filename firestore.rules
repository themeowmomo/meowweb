rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Fixed: Non-recursive admin check
    // This function checks if a record exists for the user in the app_admins collection.
    // The rules for app_admins allow a user to 'get' their own record, allowing this exists() to work.
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/app_admins/$(request.auth.uid));
    }

    // Admin collection rules
    match /app_admins/{userId} {
      // Crucial: Allow users to check their own admin status without a recursive isAdmin call.
      // This is what the isAdmin() helper function above uses via exists().
      allow get: if isOwner(userId);
      
      // Global admins can manage the admin list
      allow list, write: if isAdmin();
    }

    // Restaurant profile rules
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if isAdmin();

      // Orders subcollection rules
      match /orders/{orderId} {
        // Staff can read all orders.
        // Customers can only read/list their own orders (must use customerId filter for listing).
        allow read: if isAdmin() || (isSignedIn() && (resource == null || resource.data.customerId == request.auth.uid));
        
        // Any signed-in user can place an order
        allow create: if isSignedIn();
        
        // Only staff can modify or remove orders
        allow update, delete: if isAdmin();

        match /orderItems/{orderItemId} {
          // Allow reading items if user owns the parent order or is an admin
          allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/restaurants/$(restaurantId)/orders/$(orderId)).data.customerId == request.auth.uid);
          allow create: if isSignedIn();
          allow update, delete: if isAdmin();
        }
      }
    }
  }
}