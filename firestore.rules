
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGlobalAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/app_admins/$(request.auth.uid));
    }

    match /app_admins/{userId} {
      allow get: if isOwner(userId) || isGlobalAdmin();
      allow list, create, update: if isGlobalAdmin();
      allow delete: if false;
    }

    match /restaurants/{restaurantId} {
      allow get, list: if true;
      allow create: if isGlobalAdmin();
      allow update, delete: if isGlobalAdmin();

      match /orders/{orderId} {
        // Customers can read their own orders. Admins can read all.
        allow get, list: if isGlobalAdmin() || (isSignedIn() && (resource == null || resource.data.customerId == request.auth.uid));
        allow create: if isSignedIn();
        allow update: if isGlobalAdmin();
        allow delete: if isGlobalAdmin();

        match /orderItems/{orderItemId} {
          allow get, list: if isGlobalAdmin() || isSignedIn();
          allow create: if isSignedIn();
          allow update, delete: if isGlobalAdmin();
        }
      }
    }
  }
}
