rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGlobalAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/app_admins/$(request.auth.uid));
    }

    // Admin collection rules
    match /app_admins/{userId} {
      allow get: if isOwner(userId) || isGlobalAdmin();
      allow list, create, update: if isGlobalAdmin();
      allow delete: if false;
    }

    // Restaurant profile rules
    match /restaurants/{restaurantId} {
      allow get, list: if true;
      allow create, update, delete: if isGlobalAdmin();

      // Orders subcollection rules
      match /orders/{orderId} {
        // Explicitly handle get and list to avoid permission confusion
        allow get: if isGlobalAdmin() || (isSignedIn() && resource != null && resource.data.customerId == request.auth.uid);
        
        // List permission requires the client to query with a filter: where('customerId', '==', auth.uid)
        allow list: if isGlobalAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
        
        allow create: if isSignedIn();
        allow update, delete: if isGlobalAdmin();

        match /orderItems/{orderItemId} {
          // Items are readable if the parent order is readable
          allow read: if isGlobalAdmin() || (isSignedIn() && get(/databases/$(database)/documents/restaurants/$(restaurantId)/orders/$(orderId)).data.customerId == request.auth.uid);
          allow create: if isSignedIn();
          allow update, delete: if isGlobalAdmin();
        }
      }
    }
  }
}