rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGlobalAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/app_admins/$(request.auth.uid));
    }

    // Admin collection rules
    match /app_admins/{userId} {
      allow get: if isOwner(userId) || isGlobalAdmin();
      allow list, create, update: if isGlobalAdmin();
      allow delete: if false;
    }

    // Restaurant profile rules
    match /restaurants/{restaurantId} {
      allow get, list: if true;
      allow create, update, delete: if isGlobalAdmin();

      // Orders subcollection rules
      match /orders/{orderId} {
        // Use 'read' to cover both 'get' and 'list'
        allow read: if isGlobalAdmin() || (isSignedIn() && (resource == null || resource.data.customerId == request.auth.uid));
        
        allow create: if isSignedIn();
        allow update, delete: if isGlobalAdmin();

        match /orderItems/{orderItemId} {
          allow read: if isGlobalAdmin() || isSignedIn();
          allow create: if isSignedIn();
          allow update, delete: if isGlobalAdmin();
        }
      }
    }
  }
}