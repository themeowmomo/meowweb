rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/app_admins/$(request.auth.uid));
    }

    // Admin collection rules
    match /app_admins/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list, write: if isAdmin();
    }

    // Restaurant profile rules
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if isAdmin();

      // Orders subcollection rules
      match /orders/{orderId} {
        // Customers can read their own orders. Staff can read all.
        // For 'list' queries, the customer MUST filter by 'customerId == auth.uid'
        allow read: if isAdmin() || (isSignedIn() && (resource == null || resource.data.customerId == request.auth.uid));
        
        // Any signed-in user can place an order
        allow create: if isSignedIn();
        
        // Only staff can modify or remove orders
        allow update, delete: if isAdmin();

        match /orderItems/{orderItemId} {
          allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/restaurants/$(restaurantId)/orders/$(orderId)).data.customerId == request.auth.uid);
          allow create: if isSignedIn();
          allow update, delete: if isAdmin();
        }
      }
    }

    // Platform Admins fallback
    match /app_admins/{userId} {
       allow read: if isOwner(userId) || isAdmin();
    }
  }
}