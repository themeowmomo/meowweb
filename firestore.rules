rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGlobalAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/app_admins/$(request.auth.uid));
    }

    // Admin collection rules
    match /app_admins/{userId} {
      allow get: if isOwner(userId) || isGlobalAdmin();
      allow list, create, update: if isGlobalAdmin();
      allow delete: if false;
    }

    // Restaurant profile rules
    match /restaurants/{restaurantId} {
      allow get, list: if true;
      allow create, update, delete: if isGlobalAdmin();

      // Orders subcollection rules
      match /orders/{orderId} {
        // List permission is granted if the user is an admin OR if the query is restricted to their own customerId
        allow list: if isGlobalAdmin() || (isSignedIn() && request.auth.uid == resource.data.customerId);
        allow get: if isGlobalAdmin() || (isSignedIn() && request.auth.uid == resource.data.customerId);
        
        // Signed in users can create orders
        allow create: if isSignedIn();
        
        // Only admins can modify status or delete orders
        allow update, delete: if isGlobalAdmin();

        // Order items rules
        match /orderItems/{orderItemId} {
          allow get, list: if isGlobalAdmin() || isSignedIn();
          allow create: if isSignedIn();
          allow update, delete: if isGlobalAdmin();
        }
      }
    }
  }
}
