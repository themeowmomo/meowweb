rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if user is in the app_admins collection
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/app_admins/$(request.auth.uid));
    }

    // Admin collection rules
    match /app_admins/{userId} {
      // Allow users to check their own status for the isAdmin helper
      allow get: if request.auth.uid == userId;
      // Admins can manage the staff list
      allow list, write: if isAdmin();
    }

    // Restaurant profile rules
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if isAdmin();

      // Orders collection rules
      match /orders/{orderId} {
        // Public can place orders
        allow create: if true;
        // Only admins can view or manage orders
        allow read, update, delete: if isAdmin();

        match /orderItems/{orderItemId} {
          allow create: if true;
          allow read, update, delete: if isAdmin();
        }
      }
    }
  }
}