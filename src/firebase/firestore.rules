
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Restaurant profile rules
    match /restaurants/{restaurantId} {
      // Allow public read access to the restaurant profile
      allow get, list: if true;
      
      // Only internal system/admin (manual intervention) can write to profiles
      allow write: if false;

      // Orders subcollection rules
      match /orders/{orderId} {
        // Anyone can create an order
        allow create: if true;
        
        // Orders are private once created
        allow read: if false;
        
        allow update, delete: if false;

        match /orderItems/{orderItemId} {
          allow create: if true;
          allow read: if false;
          allow update, delete: if false;
        }
      }
    }
  }
}
