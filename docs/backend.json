
{
  "entities": {
    "RestaurantProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RestaurantProfile",
      "type": "object",
      "description": "Represents the profile and general information of a restaurant.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "googleRating": { "type": "number" },
        "priceRangeMin": { "type": "number" },
        "priceRangeMax": { "type": "number" },
        "address": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "ownerPhone": { "type": "string" },
        "businessPhone": { "type": "string" },
        "googleMapsUrl": { "type": "string", "format": "uri" },
        "whatsAppOrderUrl": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "businessHighlights": { "type": "array", "items": { "type": "string" } },
        "paymentMethods": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "category", "address", "description"]
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "description": "Represents a guest customer's complete order.",
      "properties": {
        "id": { "type": "string" },
        "restaurantId": { "type": "string" },
        "customerId": { "type": "string" },
        "orderDate": { "type": "string", "format": "date-time" },
        "customerName": { "type": "string" },
        "customerContact": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "totalAmount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "restaurantId", "customerId", "orderDate", "customerName", "totalAmount", "paymentMethod", "status"]
    },
    "OrderItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OrderItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "menuItemId": { "type": "string" },
        "quantity": { "type": "number" },
        "priceAtOrder": { "type": "number" },
        "name": { "type": "string" }
      },
      "required": ["id", "orderId", "menuItemId", "quantity", "priceAtOrder"]
    }
  },
  "firestore": {
    "structure": [
      {
        "path": "/restaurants/{restaurantId}",
        "definition": {
          "entityName": "RestaurantProfile",
          "schema": { "$ref": "#/backend/entities/RestaurantProfile" }
        }
      },
      {
        "path": "/restaurants/{restaurantId}/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": { "$ref": "#/backend/entities/Order" }
        }
      },
      {
        "path": "/restaurants/{restaurantId}/orders/{orderId}/orderItems/{orderItemId}",
        "definition": {
          "entityName": "OrderItem",
          "schema": { "$ref": "#/backend/entities/OrderItem" }
        }
      }
    ]
  }
}
